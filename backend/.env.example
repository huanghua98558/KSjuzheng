# ==== KSJuzheng Backend .env ====
# 复制为 .env 后启动. 生产环境必须改 SECRET_KEY 与 DB 路径.

# === 服务 ===
APP_NAME=KSJuzheng-Backend
APP_VERSION=0.1.0
APP_ENV=dev                    # dev / prod
DEBUG=true
HOST=0.0.0.0
PORT=8800
TIMEZONE=Asia/Shanghai

# === 安全 ===
# 生产必换! openssl rand -hex 32
SECRET_KEY=dev-secret-please-change-in-production-d4f3a8c92e1b7f6d
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30
PASSWORD_MIN_LEN=8

# === 数据库 ===
# Phase 1: SQLite WAL
DATABASE_URL=sqlite:///./data/ksjuzheng.db
# Phase 2+: PostgreSQL
# DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/ksjuzheng

DB_POOL_SIZE=10
DB_BUSY_TIMEOUT_MS=30000

# === Redis (Phase 2+) ===
# REDIS_URL=redis://127.0.0.1:6379/0

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# === 限流 ===
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_PUBLISH_BATCH=10/minute

# === 日志 ===
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_RETENTION_DAYS=14
